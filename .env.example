# ==============================================
# 🗄️ DATABASE CONFIGURATION
# ==============================================
# PostgreSQL or MySQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
# Or: mysql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/wa_gateway_db?schema=public"

# ==============================================
# 🔐 AUTHENTICATION (NextAuth.js)
# ==============================================
# Generate a secure secret with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-at-least-32-chars-change-this-in-production"

# Unified Base URL (Change this to your domain)
BASE_URL="http://localhost:3000"

# References BASE_URL
NEXTAUTH_URL="${BASE_URL}"
# Trust host for production deployment (required for proxied/reverse-proxy environments)
# Set to "true" if behind nginx, cloudflare, or similar proxy
AUTH_TRUST_HOST="true"

# ==============================================
# 🚀 APPLICATION SETTINGS
# ==============================================
# Environment: development | production | test  
NODE_ENV="development"

# Server Configuration
PORT="3000"
HOSTNAME="localhost"

# Public URLs (Derived from BASE_URL)
NEXT_PUBLIC_APP_URL="${BASE_URL}"
NEXT_PUBLIC_API_URL="${BASE_URL}/api"

# ==============================================
# 🎨 BRANDING & UI
# ==============================================
# Application name displayed in UI
APP_NAME="pegawat"

# Logo URL (optional, leave empty to use default)
LOGO_URL=""

# Favicon URL (optional, leave empty to use default)
FAVICON_URL=""

# ==============================================
# � SEO & DISCOVERABILITY
# ==============================================
# Global toggle to allow Google/Bots to crawl this site instance (true = public indexable)
NEXT_PUBLIC_ALLOW_INDEXING="false"

# ==============================================
# �🔌 EXTERNAL INTEGRATIONS
# ==============================================
# Remove.bg API Key for Sticker Background Removal
# Get your key from: https://www.remove.bg/api
REMOVE_BG_API_KEY=""

# ==============================================
# 📝 LOGGING & DEBUGGING
# ==============================================
# Baileys Logging Level: fatal | error | warn | info | debug | trace
# Recommended: error for production, debug for development
BAILEYS_LOG_LEVEL="error"

# ==============================================
# 📚 SWAGGER API DOCUMENTATION
# ==============================================
# Credentials for accessing Swagger UI at /docs
# Change these in production!
NEXT_PUBLIC_SWAGGER_USERNAME="admin"
NEXT_PUBLIC_SWAGGER_PASSWORD="admin123"

# Enable/disable Swagger UI
NEXT_PUBLIC_SWAGGER_ENABLED="true"

# ==============================================
# 🔔 NOTIFICATIONS (Optional)
# ==============================================
# Enable system notifications
ENABLE_NOTIFICATIONS="true"

# ==============================================
# ⚙️ ADVANCED SETTINGS (Optional)
# ==============================================
# Session timeout in hours
SESSION_TIMEOUT_HOURS="24"

# Max file upload size in MB
MAX_UPLOAD_SIZE_MB="50"

# Enable rate limiting
ENABLE_RATE_LIMITING="true"

# Rate limit: requests per minute
RATE_LIMIT_PER_MINUTE="60"

# ==============================================
# 🌍 LOCALIZATION (Optional)
# ==============================================
# Timezone for scheduled messages
TZ="Asia/Jakarta"

# Locale for date/time formatting
LOCALE="id-ID"

# ==============================================
# 📊 ANALYTICS (Optional)
# ==============================================
# Google Analytics ID (leave empty to disable)
NEXT_PUBLIC_GA_ID=""

# ==============================================
# 🔧 FEATURE FLAGS (Optional)
# ==============================================
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES="false"

# Enable auto-updates check
ENABLE_AUTO_UPDATE_CHECK="true"

# ==============================================
# 💾 BACKUP & STORAGE (Optional)
# ==============================================
# Media storage path (relative to project root)
MEDIA_STORAGE_PATH="uploads"

# Backup schedule (cron format)
# BACKUP_SCHEDULE="0 2 * * *"

# ==============================================
# ⚠️ NOTES
# ==============================================
# 1. Copy this file to .env before running the application
# 2. Never commit .env file to version control
# 3. Update values according to your environment
# 4. Generate secure AUTH_SECRET for production
# 5. Change Swagger credentials for production
# 6. Make sure DATABASE_URL is correct for your database
#
# For more information, visit:
# https://github.com/mrifqidaffaaditya/pegawat
